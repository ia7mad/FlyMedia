<Window x:Class="MediaOverlay.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FlyMedia — Settings"
        Width="400"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        RenderOptions.BitmapScalingMode="HighQuality">

    <Window.Resources>

        <!-- ── Toggle switch (coral accent, matches play button) ── -->
        <Style x:Key="Toggle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="40" Height="22">
                            <Border x:Name="Track" CornerRadius="11"
                                    Background="#33FFFFFF"/>
                            <Border x:Name="Knob" Width="16" Height="16" CornerRadius="8"
                                    Background="#777777"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="3,0,0,0">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.4" Color="Black"/>
                                </Border.Effect>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#FD8880"/>
                                <Setter TargetName="Knob"  Property="Background" Value="#FFFFFF"/>
                                <Setter TargetName="Knob"  Property="Margin"     Value="21,0,0,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Combo / dropdown ── -->
        <Style x:Key="Combo" TargetType="ComboBox">
            <Setter Property="Background"              Value="#1AFFFFFF"/>
            <Setter Property="Foreground"              Value="#EEEEEE"/>
            <Setter Property="FontFamily"              Value="Segoe UI"/>
            <Setter Property="FontSize"                Value="12"/>
            <Setter Property="BorderBrush"             Value="#33FFFFFF"/>
            <Setter Property="BorderThickness"         Value="1"/>
            <Setter Property="Padding"                 Value="10,5"/>
            <Setter Property="Cursor"                  Value="Hand"/>
            <Setter Property="MinWidth"                Value="130"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>

            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground"  Value="#EEEEEE"/>
                        <Setter Property="Background"  Value="Transparent"/>
                        <Setter Property="FontFamily"  Value="Segoe UI"/>
                        <Setter Property="FontSize"    Value="12"/>
                        <Setter Property="Padding"     Value="12,7"/>
                        <Setter Property="Cursor"      Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#1AFFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#33FD8880"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Box"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="24"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      IsHitTestVisible="False"/>
                                    <TextBlock Grid.Column="1"
                                               Text="&#xE70D;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="9"
                                               Foreground="#777777"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               IsHitTestVisible="False"/>
                                    <ToggleButton Grid.ColumnSpan="2"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  Background="Transparent" BorderThickness="0" Focusable="False"/>
                                </Grid>
                            </Border>

                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="#1E1E1E"
                                        BorderBrush="#33FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Margin="0,4,0,0"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="20" ShadowDepth="6" Opacity="0.6" Color="Black"/>
                                    </Border.Effect>
                                    <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#55FFFFFF"/>
                                <Setter TargetName="Box" Property="Background"  Value="#22FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#FD8880"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Same pill card as MainWindow -->
    <Border CornerRadius="14"
            Margin="16"
            BorderBrush="#22FFFFFF"
            BorderThickness="1"
            SnapsToDevicePixels="True">

        <Border.Background>
            <SolidColorBrush Color="#141414" Opacity="0.96"/>
        </Border.Background>

        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="8" Color="#000000" Opacity="0.65"/>
        </Border.Effect>

        <Grid Margin="20,16,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- header -->
                <RowDefinition Height="Auto"/>  <!-- divider -->
                <RowDefinition Height="Auto"/>  <!-- content -->
            </Grid.RowDefinitions>

            <!-- ── Header ── -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Settings"
                               Foreground="#FFFFFF"
                               FontFamily="Segoe UI"
                               FontSize="16"
                               FontWeight="Bold"/>
                    <TextBlock Text="FlyMedia preferences"
                               Foreground="#777777"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               Margin="0,2,0,0"/>
                </StackPanel>
                <!-- Close -->
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Width="28" Height="28"
                        Click="CloseButton_Click"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="Transparent" CornerRadius="14">
                                <TextBlock Text="&#xE711;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="12"
                                           Foreground="#777777"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#1AFFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <Border Grid.Row="1" Height="1" Background="#1AFFFFFF" Margin="0,0,0,16"/>

            <!-- ── Settings rows ── -->
            <StackPanel Grid.Row="2">

                <!-- GENERAL -->
                <TextBlock Text="GENERAL"
                           Foreground="#555555"
                           FontFamily="Segoe UI"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <!-- Start with Windows -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Start with Windows"
                                   Foreground="#EEEEEE" FontFamily="Segoe UI" FontSize="13"/>
                        <TextBlock Text="Launch automatically on sign-in"
                                   Foreground="#777777" FontFamily="Segoe UI" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox x:Name="ChkStartWithWindows" Grid.Column="1"
                              Style="{StaticResource Toggle}" VerticalAlignment="Center"
                              Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                </Grid>

                <!-- Show in Taskbar -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Show in taskbar"
                                   Foreground="#EEEEEE" FontFamily="Segoe UI" FontSize="13"/>
                        <TextBlock Text="Show FlyMedia button in the taskbar"
                                   Foreground="#777777" FontFamily="Segoe UI" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox x:Name="ChkShowInTaskbar" Grid.Column="1"
                              Style="{StaticResource Toggle}" VerticalAlignment="Center"
                              Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                </Grid>

                <!-- Auto-hide -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Auto-hide flyout"
                                   Foreground="#EEEEEE" FontFamily="Segoe UI" FontSize="13"/>
                        <TextBlock Text="Hides the media card after inactivity"
                                   Foreground="#777777" FontFamily="Segoe UI" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                    <ComboBox x:Name="CmbAutoHide" Grid.Column="1"
                              Style="{StaticResource Combo}" VerticalAlignment="Center"
                              SelectionChanged="Setting_Changed"/>
                </Grid>

                <Border Height="1" Background="#1AFFFFFF" Margin="0,12,0,12"/>

                <!-- FLYOUT -->
                <TextBlock Text="FLYOUT"
                           Foreground="#555555"
                           FontFamily="Segoe UI"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <!-- Flyout position -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Flyout position"
                                   Foreground="#EEEEEE" FontFamily="Segoe UI" FontSize="13"/>
                        <TextBlock Text="Corner where the media card appears"
                                   Foreground="#777777" FontFamily="Segoe UI" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                    <ComboBox x:Name="CmbFlyoutPosition" Grid.Column="1"
                              Style="{StaticResource Combo}" VerticalAlignment="Center"
                              SelectionChanged="Setting_Changed"/>
                </Grid>

                <!-- Compact mode -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Compact mode"
                                   Foreground="#EEEEEE" FontFamily="Segoe UI" FontSize="13"/>
                        <TextBlock Text="Hide album art for a smaller footprint"
                                   Foreground="#777777" FontFamily="Segoe UI" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox x:Name="ChkCompact" Grid.Column="1"
                              Style="{StaticResource Toggle}" VerticalAlignment="Center"
                              Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                </Grid>

                <Border Height="1" Background="#1AFFFFFF" Margin="0,12,0,12"/>

                <!-- TASKBAR WIDGET -->
                <TextBlock Text="TASKBAR WIDGET"
                           Foreground="#555555"
                           FontFamily="Segoe UI"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <!-- Show widget -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Show taskbar widget"
                                   Foreground="#EEEEEE" FontFamily="Segoe UI" FontSize="13"/>
                        <TextBlock Text="Mini player pinned to the taskbar"
                                   Foreground="#777777" FontFamily="Segoe UI" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox x:Name="ChkTaskbarWidget" Grid.Column="1"
                              Style="{StaticResource Toggle}" VerticalAlignment="Center"
                              Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                </Grid>

                <!-- Widget position -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Widget position"
                                   Foreground="#EEEEEE" FontFamily="Segoe UI" FontSize="13"/>
                        <TextBlock Text="Where on the taskbar the widget sits"
                                   Foreground="#777777" FontFamily="Segoe UI" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                    <ComboBox x:Name="CmbWidgetSide" Grid.Column="1"
                              Style="{StaticResource Combo}" VerticalAlignment="Center"
                              SelectionChanged="Setting_Changed"/>
                </Grid>

                <Border Height="1" Background="#1AFFFFFF" Margin="0,12,0,12"/>

                <!-- PLAYBACK -->
                <TextBlock Text="PLAYBACK"
                           Foreground="#555555"
                           FontFamily="Segoe UI"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <!-- Pause other apps -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Pause other apps automatically"
                                   Foreground="#EEEEEE" FontFamily="Segoe UI" FontSize="13"/>
                        <TextBlock Text="Pause competing sessions when a new source starts"
                                   Foreground="#777777" FontFamily="Segoe UI" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox x:Name="ChkAutoPause" Grid.Column="1"
                              Style="{StaticResource Toggle}" VerticalAlignment="Center"
                              Checked="Setting_Changed" Unchecked="Setting_Changed"/>
                </Grid>

                <!-- Footer -->
                <Border Height="1" Background="#1AFFFFFF" Margin="0,16,0,12"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Foreground="#333333" FontFamily="Segoe UI" FontSize="11">
                        <Run Text="FlyMedia  ·  v1.0  ·  "/>
                        <Hyperlink NavigateUri="https://github.com/ia7mad/FlyMedia"
                                   RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="#555555"
                                   TextDecorations="None">
                            <Run Text="GitHub"/>
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>

            </StackPanel>
        </Grid>
    </Border>
</Window>
