<Window x:Class="MediaOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MediaOverlay.ViewModels"
        xmlns:conv="clr-namespace:MediaOverlay.Converters"
        xmlns:ctrl="clr-namespace:MediaOverlay.Controls"
        Title="FlyMedia"
        Width="380"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        RenderOptions.BitmapScalingMode="HighQuality">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <conv:BoolToPlayPauseConverter x:Key="Conv" />

        <!-- ── Premium track slider (Sleek seekbar / volume) ── -->
        <Style x:Key="TrackSlider" TargetType="Slider">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <!-- Empty track background -->
                            <Border x:Name="TrackBg" Height="4" CornerRadius="2"
                                    Background="#22FFFFFF" VerticalAlignment="Center" />
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <!-- Filled track -->
                                                <Border Height="4" CornerRadius="2"
                                                        Background="#FD8880" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="SliderThumb" Focusable="False" Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid Background="Transparent" Width="0" ClipToBounds="False">
                                                    <!-- Invisible hit box so it's easy to grab -->
                                                    <Rectangle Fill="Transparent" Width="24" Height="24" Margin="-12,-12"/>
                                                    <!-- Visible dot -->
                                                    <Ellipse x:Name="ThumbDot"
                                                             Width="12" Height="12"
                                                             Margin="-6,-6"
                                                             Fill="#FFFFFF"
                                                             Opacity="0"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.4"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbDot" Property="Opacity" Value="1"/>
                                                        <Setter TargetName="ThumbDot" Property="Width" Value="14"/>
                                                        <Setter TargetName="ThumbDot" Property="Height" Value="14"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbDot" Property="Opacity" Value="1"/>
                                                        <Setter TargetName="ThumbDot" Property="Width" Value="14"/>
                                                        <Setter TargetName="ThumbDot" Property="Height" Value="14"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2" Background="Transparent" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <!-- Track Hover Interaction -->
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TrackBg" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Icon button (prev / next / shuffle / repeat) ── -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1AFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#33FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Accent squircle play/pause button (Coral/Pink) ── -->
        <Style x:Key="PlayPauseButton" TargetType="Button">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Background" Value="#FD8880" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#FFA29B" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#E2736C" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════════════════════
         Pill card — drop shadow + margin so the shadow is not clipped.
    ════════════════════════════════════════════════════════════════════════ -->
    <Border x:Name="PillBorder"
            CornerRadius="14"
            Margin="16"
            MouseLeftButtonDown="Border_MouseLeftButtonDown"
            MouseEnter="PillBorder_MouseEnter"
            MouseLeave="PillBorder_MouseLeave"
            BorderBrush="#22FFFFFF"
            BorderThickness="1"
            SnapsToDevicePixels="True">

        <Border.Background>
            <!-- Very dark, almost black semi-transparent background to let Acrylic shine -->
            <SolidColorBrush Color="#141414" Opacity="0.88" />
        </Border.Background>

        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="8"
                              Color="#000000" Opacity="0.65" />
        </Border.Effect>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />   <!-- ROW 0: album art / info / controls -->
                <RowDefinition Height="Auto" />   <!-- ROW 1: seekbar -->
                <RowDefinition Height="Auto" />   <!-- ROW 2: volume -->
            </Grid.RowDefinitions>

            <!-- ── Settings gear (top-right, floats above all rows) ── -->
            <Button Grid.Row="0"
                    Width="22" Height="22"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,-2,-2,0"
                    Click="SettingsButton_Click"
                    Panel.ZIndex="10"
                    Style="{StaticResource IconButton}">
                <TextBlock Text="&#xE713;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="14"
                           Foreground="#AAAAAA" />
            </Button>

            <!-- ══ ROW 0 — album art · info · controls ═══════════════════ -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />   <!-- Album Art -->
                    <ColumnDefinition Width="*"    />   <!-- Details & Controls -->
                </Grid.ColumnDefinitions>

                <!-- ── Album art (80x80 matched to image proportions) ── -->
                <Border Grid.Column="0"
                        Width="84" Height="84"
                        CornerRadius="8"
                        ClipToBounds="True"
                        VerticalAlignment="Center"
                        Margin="0,0,16,0"
                        Visibility="{Binding IsCompact,
                            Converter={StaticResource Conv},
                            ConverterParameter=invert}">
                    <Grid>
                        <Rectangle Fill="#202020" />
                        <TextBlock Text="&#xE8D6;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="26"
                                   Foreground="#33FFFFFF"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding HasAlbumArt,
                                       Converter={StaticResource Conv},
                                       ConverterParameter=invert}" />
                        <Image Source="{Binding AlbumArt}" Stretch="UniformToFill" />
                        <!-- Subtle inner ring over album art -->
                        <Border BorderBrush="#1AFFFFFF" BorderThickness="1" CornerRadius="8" />
                    </Grid>
                </Border>

                <!-- ── Info and Controls Block ── -->
                <Grid Grid.Column="1">
                    <ctrl:AudioVisualizer HorizontalAlignment="Stretch"
                                          VerticalAlignment="Bottom"
                                          Height="50"
                                          Opacity="0.15"
                                          BarColor="#FD8880"
                                          Margin="0,0,0,10" />

                    <StackPanel VerticalAlignment="Center">
                    
                    <!-- Song Title (scrolls when text is wider than the container) -->
                    <Grid x:Name="SongTitleContainer"
                          ClipToBounds="True"
                          Margin="0,0,26,2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="SongTitleText"
                                       Text="{Binding SongTitle}"
                                       Foreground="#FFFFFF"
                                       FontFamily="Segoe UI"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Left">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform x:Name="SongTitleTranslate" X="0"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <!-- Artist -->
                    <TextBlock Text="{Binding Artist}"
                               Foreground="#9B9B9B"
                               FontFamily="Segoe UI"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,0,12" />

                    <!-- Bottom row of controls -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" /> <!-- Prev -->
                            <ColumnDefinition Width="Auto" /> <!-- Play/Pause -->
                            <ColumnDefinition Width="Auto" /> <!-- Next -->
                            <ColumnDefinition Width="*" />    <!-- Spacer -->
                            <ColumnDefinition Width="Auto" /> <!-- Source App -->
                        </Grid.ColumnDefinitions>

                        <!-- Previous -->
                        <Button Grid.Column="0"
                                Style="{StaticResource IconButton}"
                                Command="{Binding PreviousCommand}"
                                ToolTip="Previous"
                                VerticalAlignment="Center">
                            <TextBlock Text="&#xE892;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Foreground="#EEEEEE" />
                        </Button>

                        <!-- Play / Pause -->
                        <Button Grid.Column="1"
                                Style="{StaticResource PlayPauseButton}"
                                Command="{Binding PlayPauseCommand}"
                                ToolTip="Play / Pause"
                                Margin="12,0"
                                VerticalAlignment="Center">
                            <Grid Width="16" Height="16">
                                <TextBlock Text="&#xE768;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16"
                                           Foreground="#000000"
                                           FontWeight="Black"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsPlaying,
                                               Converter={StaticResource Conv},
                                               ConverterParameter=play}" />
                                <TextBlock Text="&#xE769;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16"
                                           Foreground="#000000"
                                           FontWeight="Black"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsPlaying,
                                               Converter={StaticResource Conv},
                                               ConverterParameter=pause}" />
                            </Grid>
                        </Button>

                        <!-- Next -->
                        <Button Grid.Column="2"
                                Style="{StaticResource IconButton}"
                                Command="{Binding NextCommand}"
                                ToolTip="Next"
                                VerticalAlignment="Center">
                            <TextBlock Text="&#xE893;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Foreground="#EEEEEE" />
                        </Button>

                        <!-- Source App (Right aligned) -->
                        <StackPanel Grid.Column="4"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding HasSourceApp,
                                        Converter={StaticResource Conv},
                                        ConverterParameter=pause}">
                            <TextBlock Text="&#xE8D6;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="11"
                                       Foreground="#666666"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0" />
                            <TextBlock Text="{Binding SourceApp}"
                                       Foreground="#666666"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>

            <!-- ══ ROW 1 — seek bar ══════════════════════════════════════ -->
            <Grid Grid.Row="1" Margin="0,16,0,0"
                  Visibility="{Binding CanSeek,
                      Converter={StaticResource Conv},
                      ConverterParameter=pause}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="36" />   <!-- Elapsed Time -->
                    <ColumnDefinition Width="*"  />   <!-- Slider -->
                    <ColumnDefinition Width="36" />   <!-- Total Time -->
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding PositionText}"
                           Foreground="#777777"
                           FontFamily="Segoe UI"
                           FontSize="10"
                           FontWeight="Medium"
                           VerticalAlignment="Center" />

                <Slider Grid.Column="1"
                        x:Name="SeekSlider"
                        Minimum="0" Maximum="1"
                        Value="{Binding SeekPosition, Mode=TwoWay, Delay=50}"
                        VerticalAlignment="Center"
                        Style="{StaticResource TrackSlider}"
                        Margin="8,0"
                        Thumb.DragStarted="SeekSlider_DragStarted"
                        Thumb.DragCompleted="SeekSlider_DragCompleted" />

                <TextBlock Grid.Column="2"
                           Text="{Binding RemainingText}"
                           Foreground="#777777"
                           FontFamily="Segoe UI"
                           FontSize="10"
                           FontWeight="Medium"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right" />
            </Grid>

            <!-- ══ ROW 2 — volume control ══════════════════════════════ -->
            <!-- Optional visually: maybe hide volume if you strictly want ONLY the design in the image, 
                 but keeping it functional is safer. It adopts the same sleek styling. -->
            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="36" />
                    <ColumnDefinition Width="*"  />
                    <ColumnDefinition Width="36" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource IconButton}"
                        Command="{Binding MuteToggleCommand}"
                        ToolTip="Mute / Unmute"
                        HorizontalAlignment="Left"
                        Width="24" Height="24">
                    <TextBlock Text="{Binding VolumeIcon}"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="12"
                               Foreground="#777777" />
                </Button>

                <Slider Grid.Column="1"
                        Minimum="0" Maximum="100"
                        Value="{Binding Volume, Mode=TwoWay, Delay=50}"
                        VerticalAlignment="Center"
                        Style="{StaticResource TrackSlider}"
                        Margin="8,0" />

                <TextBlock Grid.Column="2"
                           Text="{Binding Volume, StringFormat={}{0:0}%}"
                           Foreground="#777777"
                           FontFamily="Segoe UI"
                           FontSize="10"
                           FontWeight="Medium"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right" />
            </Grid>
        </Grid>
    </Border>
</Window>
