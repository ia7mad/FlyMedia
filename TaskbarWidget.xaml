<Window x:Class="MediaOverlay.TaskbarWidget"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MediaOverlay.ViewModels"
        xmlns:conv="clr-namespace:MediaOverlay.Converters"
        xmlns:ctrl="clr-namespace:MediaOverlay.Controls"
        Title="FlyMedia Widget"
        SizeToContent="Width"
        Height="48"
        MinWidth="60"
        MaxWidth="320"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        RenderOptions.BitmapScalingMode="HighQuality">

    <Window.Resources>
        <conv:BoolToPlayPauseConverter x:Key="Conv" />
    </Window.Resources>

    <!-- Sleek mini-player strip that sits just above the taskbar -->
    <Border x:Name="WidgetBorder"
            Background="#CC121212"
            CornerRadius="10"
            Margin="4"
            MouseLeftButtonDown="Widget_MouseLeftButtonDown"
            MouseEnter="Widget_MouseEnter"
            MouseLeave="Widget_MouseLeave"
            Cursor="Hand"
            BorderBrush="#33FFFFFF"
            BorderThickness="1"
            SnapsToDevicePixels="True">

        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2"
                              Color="#000000" Opacity="0.5" />
        </Border.Effect>

        <Grid Margin="6,4,10,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />   <!-- Album art -->
                <ColumnDefinition Width="Auto" />   <!-- Song info -->
            </Grid.ColumnDefinitions>

            <!-- Album Art Thumbnail -->
            <Border Grid.Column="0"
                    Width="34" Height="34"
                    CornerRadius="6"
                    ClipToBounds="True"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0">
                <Grid>
                    <Rectangle Fill="#1A1A1A" />
                    <!-- Music note fallback -->
                    <TextBlock Text="&#xE8D6;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="16"
                               Foreground="#44FFFFFF"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="{Binding HasAlbumArt,
                                   Converter={StaticResource Conv},
                                   ConverterParameter=invert}" />
                    <!-- Actual album art -->
                    <Image Source="{Binding AlbumArt}" 
                           Stretch="UniformToFill"/>
                    <!-- Subtle inner ring -->
                    <Border BorderBrush="#18FFFFFF" BorderThickness="1" CornerRadius="6" />
                </Grid>
            </Border>

            <!-- Song Title + Artist -->
            <Grid Grid.Column="1" MinWidth="80">
                <ctrl:AudioVisualizer HorizontalAlignment="Stretch"
                                      VerticalAlignment="Bottom"
                                      Height="28"
                                      Opacity="0.15"
                                      BarColor="#FD8880"
                                      Margin="0,0,0,2" />

                <StackPanel VerticalAlignment="Center"
                            MaxWidth="200">
                    <Grid x:Name="SongTitleContainer" ClipToBounds="True" Margin="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="SongTitleText"
                                       Text="{Binding SongTitle}"
                                       Foreground="#FFFFFF"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Left">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform x:Name="SongTitleTranslate" X="0"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="{Binding Artist}"
                               Foreground="#88FFFFFF"
                               FontFamily="Segoe UI"
                               FontSize="10"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
